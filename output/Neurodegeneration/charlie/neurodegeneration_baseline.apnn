\arc{A_16}{\from{CHOP} \to{T_CHOP_off} \weight{1} \type{ordinary}}
\arc{A_17}{\from{CytoC} \to{T_CASP9_on} \weight{1} \type{ordinary}}
\arc{A_18}{\from{T_CASP9_on} \to{CASP9} \weight{1} \type{ordinary}}
\arc{A_19}{\from{CASP9} \to{T_CASP9_off} \weight{1} \type{ordinary}}
\arc{A_20}{\from{CASP9} \to{T_CASP3_from_CASP9} \weight{1} \type{ordinary}}
\arc{A_21}{\from{T_CASP3_from_CASP9} \to{CASP9} \weight{1} \type{ordinary}}
\arc{A_22}{\from{T_CASP3_from_CASP9} \to{CASP3} \weight{1} \type{ordinary}}
\arc{A_23}{\from{CHOP} \to{T_CASP3_from_CHOP} \weight{1} \type{ordinary}}
