\transition{T_CASP3_off}{\name{T_CASP3_off}}
\transition{T_Apoptosis}{\name{T_Apoptosis}}
\transition{T_Neurodegeneration}{\name{T_Neurodegeneration}}

\arc{A_0}{\from{Ca_in} \to{T_Ca_mito} \weight{1} \type{ordinary}}
\arc{A_1}{\from{T_Ca_mito} \to{Ca_mito} \weight{1} \type{ordinary}}
\arc{A_2}{\from{Ca_mito} \to{T_DeltaPsi_loss} \weight{1} \type{ordinary}}
