\beginnet{Downstream_Baseline_Ca2_CASP3_Neurodegeneration}

\place{Ca_in}{\name{Ca_in}\init{35}}
\place{Ca_mito}{\name{Ca_mito}\init{0}}
\place{DeltaPsi}{\name{DeltaPsi}\capacity{6}\init{6}}
\place{CytoC}{\name{CytoC}\init{0}}
\place{ROS}{\name{ROS}\init{0}}
\place{ER_stress}{\name{ER_stress}\init{0}}
\place{CHOP}{\name{CHOP}\init{0}}
\place{CASP9}{\name{CASP9}\init{0}}
\place{CASP3}{\name{CASP3}\init{0}}
\place{Apoptosis}{\name{Apoptosis}\init{0}}
\place{Neurodegeneration}{\name{Neurodegeneration}\init{0}}

\transition{T_Ca_mito}{\name{T_Ca_mito}}
\transition{T_DeltaPsi_loss}{\name{T_DeltaPsi_loss}}
\transition{T_CytoC_release}{\name{T_CytoC_release}}
\transition{T_ROS_on}{\name{T_ROS_on}}
