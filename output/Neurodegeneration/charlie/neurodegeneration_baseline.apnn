\arc{A_4}{\from{T_DeltaPsi_loss} \to{Ca_mito} \weight{1} \type{ordinary}}
\arc{A_5}{\from{Ca_mito} \to{T_CytoC_release} \weight{1} \type{ordinary}}
\arc{A_6}{\from{T_CytoC_release} \to{CytoC} \weight{1} \type{ordinary}}
\arc{A_7}{\from{Ca_in} \to{T_ROS_on} \weight{1} \type{ordinary}}
\arc{A_8}{\from{T_ROS_on} \to{Ca_in} \weight{1} \type{ordinary}}
\arc{A_9}{\from{T_ROS_on} \to{ROS} \weight{1} \type{ordinary}}
\arc{A_10}{\from{ROS} \to{T_ROS_off} \weight{1} \type{ordinary}}
\arc{A_11}{\from{Ca_in} \to{T_ER_stress} \weight{1} \type{ordinary}}
\arc{A_12}{\from{T_ER_stress} \to{Ca_in} \weight{1} \type{ordinary}}
\arc{A_13}{\from{T_ER_stress} \to{ER_stress} \weight{1} \type{ordinary}}
