\arc{A_25}{\from{T_CASP3_from_CHOP} \to{CASP3} \weight{1} \type{ordinary}}
\arc{A_26}{\from{ROS} \to{T_CASP3_from_ROS} \weight{1} \type{ordinary}}
\arc{A_27}{\from{T_CASP3_from_ROS} \to{ROS} \weight{1} \type{ordinary}}
\arc{A_28}{\from{T_CASP3_from_ROS} \to{CASP3} \weight{1} \type{ordinary}}
