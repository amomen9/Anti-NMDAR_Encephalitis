        <attribute name="Name" id="613" net="1"><![CDATA[Baseline: Healthy NMDAR signalling]]><graphics count="1">
            <graphic x="20.00" y="20.00" id="614" net="1" show="1" state="1" pen="0,0,0" brush="255,255,255" thickness="1" xoff="25.00" yoff="20.00" grparent="625" />
          </graphics>
        </attribute>
        <attribute name="Created" id="615" net="1"><![CDATA[2026-06-17 01:07:13]]><graphics count="1">
