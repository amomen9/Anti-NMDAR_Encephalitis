          </graphics>
        </attribute>
        <attribute name="Keywords" id="619" net="1"><![CDATA[NMDAR; anti-NMDAR encephalitis; Petri net]]><graphics count="1">
            <graphic x="20.00" y="20.00" id="620" net="1" show="0" state="1" pen="0,0,0" brush="255,255,255" thickness="1" xoff="25.00" yoff="20.00" grparent="625" />
          </graphics>
        </attribute>
        <attribute name="Description" id="621" net="1"><![CDATA[Glutamatergic synapse around a single NMDAR pool. Co-agonists (glycine / D-serine), voltage-dependent Mg2+ block, Ca2+ influx, PSD-95 scaffolding, EphB2 stabilisation and downstream CaMKII -&gt; LTP cascade.]]><graphics count="1">
            <graphic x="20.00" y="20.00" id="622" net="1" show="0" state="1" pen="0,0,0" brush="255,255,255" thickness="1" xoff="25.00" yoff="20.00" grparent="625" />
          </graphics>
        </attribute>
        <attribute name="References" id="623" net="1"><![CDATA[See README.md]]><graphics count="1">
            <graphic x="20.00" y="20.00" id="624" net="1" show="0" state="1" pen="0,0,0" brush="255,255,255" thickness="1" xoff="25.00" yoff="20.00" grparent="625" />
