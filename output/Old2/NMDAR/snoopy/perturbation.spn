  <metadataclasses count="10">
    <metadataclass count="1" name="General">
      <metadata id="851" net="1">
        <attribute name="Name" id="852" net="1"><![CDATA[Perturbation: anti-NMDAR encephalitis]]><graphics count="1">
            <graphic x="20.00" y="20.00" id="853" net="1" show="1" state="1" pen="0,0,0" brush="255,255,255" thickness="1" xoff="25.00" yoff="20.00" grparent="864" />
          </graphics>
        </attribute>
        <attribute name="Created" id="854" net="1"><![CDATA[2026-06-17 01:07:13]]><graphics count="1">
            <graphic x="20.00" y="20.00" id="855" net="1" show="0" state="1" pen="0,0,0" brush="255,255,255" thickness="1" xoff="25.00" yoff="20.00" grparent="864" />
          </graphics>
        </attribute>
        <attribute name="Authors" id="856" net="1"><![CDATA[]]><graphics count="1">
            <graphic x="20.00" y="20.00" id="857" net="1" show="1" state="1" pen="0,0,0" brush="255,255,255" thickness="1" xoff="25.00" yoff="20.00" grparent="864" />
          </graphics>
        </attribute>
        <attribute name="Keywords" id="858" net="1"><![CDATA[NMDAR; anti-NMDAR encephalitis; Petri net]]><graphics count="1">
            <graphic x="20.00" y="20.00" id="859" net="1" show="0" state="1" pen="0,0,0" brush="255,255,255" thickness="1" xoff="25.00" yoff="20.00" grparent="864" />
          </graphics>
        </attribute>
        <attribute name="Description" id="860" net="1"><![CDATA[Patient IgG against the GluN1 amino-terminal domain binds surface NMDARs, is bivalently crosslinked, displaces the EphB2-NMDAR interaction (Mikasova 2012), and drives clathrin-mediated endocytosis -&gt; lysosomal degradation (Hughes 2010, Moscato 2014). Net effect: progressive loss of synaptic NMDARs and a fall in Ca2+ influx.]]><graphics count="1">
            <graphic x="20.00" y="20.00" id="861" net="1" show="0" state="1" pen="0,0,0" brush="255,255,255" thickness="1" xoff="25.00" yoff="20.00" grparent="864" />
          </graphics>
        </attribute>
        <attribute name="References" id="862" net="1"><![CDATA[See README.md]]><graphics count="1">
            <graphic x="20.00" y="20.00" id="863" net="1" show="0" state="1" pen="0,0,0" brush="255,255,255" thickness="1" xoff="25.00" yoff="20.00" grparent="864" />
          </graphics>
        </attribute>
        <graphics count="1">
          <graphic x="20.00" y="20.00" id="864" net="1" show="1" state="1" pen="255,255,255" brush="255,255,255" thickness="1" w="1.00" h="1.00" />
        </graphics>
      </metadata>
    </metadataclass>
